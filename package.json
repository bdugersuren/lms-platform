{
  "name": "lms-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade AI-native Learning Management System — monorepo root",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,json,md}\" --ignore-path .gitignore",
    "docs:generate": "node scripts/generate-docs.js",
    "docs:arch": "node scripts/generate-docs.js",
    "docs:compose": "node scripts/generate-compose-docs.js",
    "docs:openapi": "node scripts/generate-openapi.js",
    "docs:markdown": "node scripts/generate-api-markdown.js",
    "docs": "node scripts/generate-docs.js && node scripts/generate-compose-docs.js && node scripts/generate-openapi.js && node scripts/generate-api-markdown.js",
    "docs:verify:services": "node scripts/verify-services.js",
    "docs:verify": "node scripts/verify-services.js && node scripts/verify-docs.js",
    "verify:compose": "node scripts/verify-compose.js",
    "prisma:generate": "turbo run prisma:generate",
    "docker:infra": "docker compose up -d",
    "docker:core": "docker compose --profile core up -d",
    "docker:learn": "docker compose --profile core --profile learn up -d",
    "docker:finance": "docker compose --profile core --profile finance up -d",
    "docker:ops": "docker compose --profile core --profile ops up -d",
    "docker:full": "docker compose --profile core --profile learn --profile finance --profile ops --profile frontend up -d",
    "docker:ai": "docker compose --profile core --profile ai up -d",
    "docker:down": "docker compose --profile core --profile learn --profile finance --profile ops --profile frontend --profile ai down",
    "docker:down:volumes": "docker compose --profile core --profile learn --profile finance --profile ops --profile frontend --profile ai down -v",
    "docker:logs": "docker compose logs -f",
    "docker:build": "DOCKER_BUILDKIT=1 docker compose build",
    "docker:build:nocache": "DOCKER_BUILDKIT=1 docker compose build --no-cache",
    "bootstrap": "bash scripts/bootstrap.sh",
    "migrate": "bash scripts/migrate.sh",
    "seed": "bash scripts/seed.sh",
    "dev:gateway": "pnpm --filter @lms/gateway start:dev",
    "dev:auth": "pnpm --filter @lms/auth-service start:dev",
    "dev:user": "pnpm --filter @lms/user-service start:dev",
    "dev:tenant": "pnpm --filter @lms/tenant-service start:dev",
    "dev:course": "pnpm --filter @lms/course-service start:dev",
    "dev:enrollment": "pnpm --filter @lms/enrollment-service start:dev",
    "dev:quiz": "pnpm --filter @lms/quiz-service start:dev",
    "dev:assignment": "pnpm --filter @lms/assignment-service start:dev",
    "dev:wallet": "pnpm --filter @lms/wallet-service start:dev",
    "dev:payment": "pnpm --filter @lms/payment-service start:dev",
    "dev:ai": "pnpm --filter @lms/ai-service start:dev",
    "dev:notification": "pnpm --filter @lms/notification-service start:dev",
    "dev:media": "pnpm --filter @lms/media-service start:dev",
    "dev:certificate": "pnpm --filter @lms/certificate-service start:dev",
    "dev:analytics": "pnpm --filter @lms/analytics-service start:dev",
    "dev:shared": "turbo run build:watch --filter='@lms/shared-*'",
    "dev:infra": "bash scripts/dev/start-infra.sh",
    "dev:core": "bash scripts/dev/start-core.sh",
    "dev:full": "bash scripts/dev/start-full.sh",
    "dev:ai-stack": "bash scripts/dev/start-ai.sh",
    "dev:stop": "bash scripts/dev/stop.sh",
    "dev:restart": "bash scripts/dev/restart.sh",
    "dev:logs": "bash scripts/dev/logs.sh",
    "dev:status": "bash scripts/dev/status.sh",
    "dev:reset": "bash scripts/dev/reset.sh",
    "db:migrate": "bash scripts/db/migrate.sh",
    "db:seed": "bash scripts/db/seed.sh",
    "db:reset": "bash scripts/db/reset.sh",
    "docs:all": "bash scripts/docs/generate.sh",
    "docs:check": "bash scripts/docs/verify.sh",
    "verify:services": "bash scripts/verify/services.sh",
    "verify:all": "bash scripts/verify/services.sh && bash scripts/verify/compose.sh"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.3.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.3.3",
    "typescript": "^5.4.5",
    "widdershins": "^4.0.1",
    "yaml": "^2.6.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.5.0"
  },
  "packageManager": "pnpm@9.15.9"
}
