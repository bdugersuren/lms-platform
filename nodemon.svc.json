{
  "watch": [
    "src",
    "../../packages/shared-types/src",
    "../../packages/shared-utils/src",
    "../../packages/shared-auth/src",
    "../../packages/shared-config/src"
  ],
  "ext": "ts,json",
  "ignore": ["**/*.spec.ts", "dist/**"],
  "exec": "ts-node --transpile-only -r tsconfig-paths/register src/main.ts",
  "env": {
    "TS_NODE_TRANSPILE_ONLY": "true"
  }
}
