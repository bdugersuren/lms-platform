# =============================================================================
# LMS Platform — Environment Variables Reference
# Copy this file to .env and fill in real values before running.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (shared instance — each service gets its own database)
# ---------------------------------------------------------------------------
POSTGRES_USER=lms
POSTGRES_PASSWORD=lms_secret_change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=lms
RABBITMQ_DEFAULT_PASS=lms_secret_change_me
RABBITMQ_URL=amqp://lms:lms_secret_change_me@rabbitmq:5672
RABBITMQ_EXCHANGE=lms.events

# ---------------------------------------------------------------------------
# MinIO (object storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_change_me
MINIO_USE_SSL=false
MINIO_BUCKET=lms-media
MINIO_PUBLIC_URL=http://localhost:9000
# Presigned upload URL-г browser-аас хэрэглэхийн тулд nginx /minio-store/ proxy-аар дамжуулна (CORS шийдэл).
# Production домэйнтай байршуулах бол know.mn-р солино.
MINIO_PUBLIC_STORE_URL=http://know.mn/minio-store

# ---------------------------------------------------------------------------
# Gateway Service
# ---------------------------------------------------------------------------
GATEWAY_PORT=3000
GATEWAY_NODE_ENV=development
# Production сервер дээр өөрийн домэйнийг нэмнэ
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://know.mn,https://know.mn

# Upstream service URLs (used by gateway for proxying)
AUTH_SERVICE_URL=http://auth-service:3001
TENANT_SERVICE_URL=http://tenant-service:3016
USER_SERVICE_URL=http://user-service:3014
COURSE_SERVICE_URL=http://course-service:3003
ENROLLMENT_SERVICE_URL=http://enrollment-service:3004
QUIZ_SERVICE_URL=http://quiz-service:3005
ASSIGNMENT_SERVICE_URL=http://assignment-service:3006
WALLET_SERVICE_URL=http://wallet-service:3007
PAYMENT_SERVICE_URL=http://payment-service:3008
AI_SERVICE_URL=http://ai-service:3009
NOTIFICATION_SERVICE_URL=http://notification-service:3010
MEDIA_SERVICE_URL=http://media-service:3011
CERTIFICATE_SERVICE_URL=http://certificate-service:3012
ANALYTICS_SERVICE_URL=http://analytics-service:3013
AUDIT_SERVICE_URL=http://audit-service:3015
CODING_SERVICE_URL=http://coding-service:3017

# ---------------------------------------------------------------------------
# Auth Service
# ---------------------------------------------------------------------------
AUTH_PORT=3001
AUTH_NODE_ENV=development
AUTH_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/auth_db

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_256_BIT
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET_256_BIT
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# User Service
# ---------------------------------------------------------------------------
USER_PORT=3014
USER_NODE_ENV=development
USER_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/user_db

# ---------------------------------------------------------------------------
# Tenant Service
# ---------------------------------------------------------------------------
TENANT_PORT=3016
TENANT_NODE_ENV=development
TENANT_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/tenant_db
DEFAULT_TENANT_SLUG=demo
# PLATFORM_DOMAIN: Gateway-ийн tenant resolver энэ domain-г үндсэн платформ гэж таних.
# know.mn болон www.know.mn хандалтыг DEFAULT_TENANT_SLUG (demo)-д хандуулна.
# Production сервер дээр өөрийн домэйнээр солино, жишээ нь: know.mn
PLATFORM_DOMAIN=know.mn

# ---------------------------------------------------------------------------
# Course Service
# ---------------------------------------------------------------------------
COURSE_PORT=3003
COURSE_NODE_ENV=development
COURSE_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/course_db

# ---------------------------------------------------------------------------
# Enrollment Service
# ---------------------------------------------------------------------------
ENROLLMENT_PORT=3004
ENROLLMENT_NODE_ENV=development
ENROLLMENT_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/enrollment_db

# ---------------------------------------------------------------------------
# Quiz Service
# ---------------------------------------------------------------------------
QUIZ_PORT=3005
QUIZ_NODE_ENV=development
QUIZ_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/quiz_db

# ---------------------------------------------------------------------------
# Assignment Service
# ---------------------------------------------------------------------------
ASSIGNMENT_PORT=3006
ASSIGNMENT_NODE_ENV=development
ASSIGNMENT_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/assignment_db

# ---------------------------------------------------------------------------
# Wallet Service
# ---------------------------------------------------------------------------
WALLET_PORT=3007
WALLET_NODE_ENV=development
WALLET_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/wallet_db

# ---------------------------------------------------------------------------
# Payment Service
# ---------------------------------------------------------------------------
PAYMENT_PORT=3008
PAYMENT_NODE_ENV=development
PAYMENT_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/payment_db

# ---------------------------------------------------------------------------
# AI Service
# ---------------------------------------------------------------------------
AI_PORT=3009
AI_NODE_ENV=development
AI_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/ai_db
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=120000

# ---------------------------------------------------------------------------
# Notification Service
# ---------------------------------------------------------------------------
NOTIFICATION_PORT=3010
NOTIFICATION_NODE_ENV=development
NOTIFICATION_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/notification_db

# ---------------------------------------------------------------------------
# Media Service
# ---------------------------------------------------------------------------
MEDIA_PORT=3011
MEDIA_NODE_ENV=development
MEDIA_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/media_db

# ---------------------------------------------------------------------------
# Certificate Service
# ---------------------------------------------------------------------------
CERTIFICATE_PORT=3012
CERTIFICATE_NODE_ENV=development
CERTIFICATE_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/certificate_db

# ---------------------------------------------------------------------------
# Analytics Service
# ---------------------------------------------------------------------------
ANALYTICS_PORT=3013
ANALYTICS_NODE_ENV=development
ANALYTICS_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/analytics_db

# ---------------------------------------------------------------------------
# Audit Service
# ---------------------------------------------------------------------------
AUDIT_PORT=3015
AUDIT_NODE_ENV=development
AUDIT_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/audit_db

# ---------------------------------------------------------------------------
# Coding Service (DMOJ judge adapter)
# ---------------------------------------------------------------------------
CODING_PORT=3017
CODING_NODE_ENV=development
CODING_DATABASE_URL=postgresql://lms:lms_secret_change_me@postgres:5432/coding_db

# DMOJ judge connection
DMOJ_BASE_URL=http://dmoj-site:8000
DMOJ_INTERNAL_SECRET=change-me-internal-secret
DMOJ_RESULT_SYNC_INTERVAL_MS=5000

# Service account for coding-service → assignment-service REST calls
CODING_SERVICE_ACCOUNT_EMAIL=coding-system@lms.internal
CODING_SERVICE_ACCOUNT_PASSWORD=REPLACE_WITH_SERVICE_ACCOUNT_PASSWORD

# Temporary: service JWT for grading calls (will be replaced by service-account auth)
CODING_SERVICE_JWT_OVERRIDE=
