generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProgressStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

model Enrollment {
  id              String    @id @default(uuid())
  tenantId        String    @default("demo") @map("tenant_id")
  courseId        String    @map("course_id")
  studentId       String    @map("student_id")
  progressPercent Float     @default(0) @map("progress_percent")
  totalScore      Float     @default(0) @map("total_score")
  completed       Boolean   @default(false)
  enrolledAt      DateTime  @default(now()) @map("enrolled_at")
  completedAt     DateTime? @map("completed_at")
  paymentId       String?   @map("payment_id")

  lessonProgresses       LessonProgress[]
  quizAttemptRecords     QuizAttemptRecord[]
  assignmentGradeRecords AssignmentGradeRecord[]

  @@unique([tenantId, courseId, studentId])
  @@index([tenantId])
  @@index([studentId])
  @@index([courseId])
  @@index([paymentId])
  @@map("enrollments")
}

model LessonProgress {
  id              String         @id @default(uuid())
  enrollmentId    String         @map("enrollment_id")
  lessonId        String         @map("lesson_id")
  status          ProgressStatus @default(LOCKED)
  progressPercent Float          @default(0) @map("progress_percent")
  score           Float          @default(0)
  completed       Boolean        @default(false)
  unlockedAt      DateTime?      @map("unlocked_at")
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  enrollment      Enrollment                @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  blockProgresses InteractiveBlockProgress[]

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@map("lesson_progresses")
}

model InteractiveBlockProgress {
  id                 String    @id @default(uuid())
  lessonProgressId   String    @map("lesson_progress_id")
  interactiveBlockId String    @map("interactive_block_id")
  score              Float     @default(0)
  passed             Boolean   @default(false)
  completed          Boolean   @default(false)
  attempts           Int       @default(0)
  startedAt          DateTime  @default(now()) @map("started_at")
  completedAt        DateTime? @map("completed_at")

  lessonProgress LessonProgress    @relation(fields: [lessonProgressId], references: [id], onDelete: Cascade)
  answers        InteractiveAnswer[]

  @@unique([lessonProgressId, interactiveBlockId])
  @@index([lessonProgressId])
  @@map("interactive_block_progresses")
}

model InteractiveAnswer {
  id                         String    @id @default(uuid())
  interactiveBlockProgressId String    @map("interactive_block_progress_id")
  questionId                 String    @map("question_id")
  answerText                 String?   @map("answer_text")
  selectedOptionIds          Json?     @map("selected_option_ids")
  isCorrect                  Boolean?  @map("is_correct")
  scoreAwarded               Float     @default(0) @map("score_awarded")
  answeredAt                 DateTime  @default(now()) @map("answered_at")

  interactiveBlockProgress InteractiveBlockProgress @relation(fields: [interactiveBlockProgressId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([interactiveBlockProgressId])
  @@map("interactive_answers")
}

model EnrollmentAlias {
  id                  String   @id @default(uuid())
  enrollmentServiceId String   @unique @map("enrollment_service_id")
  courseServiceId     String   @unique @map("course_service_id")
  migratedAt          DateTime @default(now()) @map("migrated_at")

  @@map("enrollment_aliases")
}

model MigrationRun {
  id           String    @id @default(uuid())
  runType      String    @map("run_type")
  status       String    @default("running")
  totalRows    Int       @default(0) @map("total_rows")
  migratedRows Int       @default(0) @map("migrated_rows")
  skippedRows  Int       @default(0) @map("skipped_rows")
  errorRows    Int       @default(0) @map("error_rows")
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorDetail  String?   @map("error_detail")
  checksum     String?

  @@index([runType, status])
  @@map("migration_runs")
}

model CourseProjection {
  courseId              String    @id @map("course_id")
  tenantId              String    @default("demo") @map("tenant_id")
  title                 String
  slug                  String
  instructorId          String    @map("instructor_id")
  price                 Decimal   @default(0) @db.Decimal(10, 2)
  status                String
  isSequential          Boolean   @default(true) @map("is_sequential")
  totalLessons          Int       @default(0) @map("total_lessons")
  totalMinutes          Int       @default(0) @map("total_minutes")
  contentVersion        Int       @default(1) @map("content_version")
  publishedAt           DateTime? @map("published_at")
  deletedAt             DateTime? @map("deleted_at")
  requireQuizPass       Boolean   @default(false) @map("require_quiz_pass")
  requireAssignmentPass Boolean   @default(false) @map("require_assignment_pass")
  minimumScorePercent   Int       @default(0) @map("minimum_score_percent")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  modules ModuleProjection[]
  lessons LessonProjection[]

  @@index([tenantId])
  @@index([status])
  @@index([instructorId])
  @@map("course_projections")
}

model ModuleProjection {
  moduleId       String    @id @map("module_id")
  courseId       String    @map("course_id")
  title          String
  sortOrder      Int       @default(0) @map("sort_order")
  contentVersion Int       @default(1) @map("content_version")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  course  CourseProjection @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  lessons LessonProjection[]

  @@index([courseId])
  @@index([courseId, sortOrder])
  @@map("module_projections")
}

model LessonProjection {
  lessonId         String    @id @map("lesson_id")
  courseId         String    @map("course_id")
  moduleId         String    @map("module_id")
  title            String
  lessonType       String    @map("lesson_type")
  sortOrder        Int       @default(0) @map("sort_order")
  passingScore     Float     @default(60) @map("passing_score")
  unlockNextOnPass Boolean   @default(true) @map("unlock_next_on_pass")
  contentVersion   Int       @default(1) @map("content_version")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  course CourseProjection @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  module ModuleProjection @relation(fields: [moduleId], references: [moduleId], onDelete: Cascade)

  @@index([courseId])
  @@index([moduleId])
  @@index([courseId, sortOrder])
  @@map("lesson_projections")
}

model QuizAttemptRecord {
  id           String     @id @default(uuid())
  enrollmentId String     @map("enrollment_id")
  quizId       String     @map("quiz_id")
  courseId     String     @map("course_id")
  passed       Boolean
  score        Decimal    @db.Decimal(10, 2)
  attemptedAt  DateTime   @default(now()) @map("attempted_at")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, quizId])
  @@index([enrollmentId])
  @@map("quiz_attempt_records")
}

model AssignmentGradeRecord {
  id           String     @id @default(uuid())
  enrollmentId String     @map("enrollment_id")
  assignmentId String     @map("assignment_id")
  courseId     String     @map("course_id")
  passed       Boolean
  score        Decimal    @db.Decimal(10, 2)
  maxScore     Decimal    @db.Decimal(10, 2)
  gradedAt     DateTime   @default(now()) @map("graded_at")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, assignmentId])
  @@index([enrollmentId])
  @@map("assignment_grade_records")
}

model EventInbox {
  id             String    @id @default(uuid())
  eventId        String    @unique @map("event_id")
  eventType      String    @map("event_type")
  aggregateType  String    @map("aggregate_type")
  aggregateId    String    @map("aggregate_id")
  contentVersion Int?      @map("content_version")
  payloadHash    String?   @map("payload_hash")
  processedAt    DateTime? @map("processed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([eventType])
  @@index([aggregateType, aggregateId])
  @@index([processedAt])
  @@map("event_inbox")
}

model EventOutbox {
  id            String    @id @default(uuid())
  eventId       String    @unique @map("event_id")
  eventType     String    @map("event_type")
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  payload       Json
  occurredAt    DateTime  @default(now()) @map("occurred_at")
  publishedAt   DateTime? @map("published_at")
  attempts      Int       @default(0)
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([eventType])
  @@index([aggregateType, aggregateId])
  @@index([publishedAt, occurredAt])
  @@map("event_outbox")
}

model EventFailure {
  id         String    @id @default(uuid())
  eventId    String?   @map("event_id")
  eventType  String    @map("event_type")
  consumer   String
  payload    Json
  errorMsg   String    @map("error_msg")
  stackTrace String?   @map("stack_trace")
  retryCount Int       @default(0) @map("retry_count")
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([eventType])
  @@index([resolvedAt])
  @@map("event_failures")
}
