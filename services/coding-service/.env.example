# Coding Service environment variables
NODE_ENV=development
PORT=3017

# PostgreSQL
DATABASE_URL=postgresql://lms:lms@localhost:5432/coding_db

# JWT (must match auth-service)
JWT_SECRET=change-me-minimum-32-characters-required
JWT_REFRESH_SECRET=change-me-minimum-32-characters-required

# RabbitMQ
RABBITMQ_URL=amqp://lms:lms@localhost:5672
RABBITMQ_EXCHANGE=lms.events

# DMOJ judge
DMOJ_BASE_URL=http://dmoj-site:8000
DMOJ_INTERNAL_SECRET=change-me-internal-secret
DMOJ_RESULT_SYNC_INTERVAL_MS=5000

# Service account (used to call assignment-service REST endpoints)
CODING_SERVICE_ACCOUNT_EMAIL=coding-system@lms.internal
CODING_SERVICE_ACCOUNT_PASSWORD=change-me-service-account-password

# Downstream services
ASSIGNMENT_SERVICE_URL=http://localhost:3006
ENROLLMENT_SERVICE_URL=http://localhost:3005
AUTH_SERVICE_URL=http://localhost:3001

# Outbox polling interval
CODING_OUTBOX_POLL_MS=5000
