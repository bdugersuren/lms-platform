# Auth Service Environment Variables
PORT=3001
NODE_ENV=development
SERVICE_NAME=auth-service

# Database
DATABASE_URL=postgresql://lms:lms_secret@postgres:5432/auth_db

# JWT
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_256_BIT
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET_256_BIT
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://lms:lms_secret@rabbitmq:5672
RABBITMQ_EXCHANGE=lms.events
