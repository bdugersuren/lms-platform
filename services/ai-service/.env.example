# AI Service
PORT=3009
NODE_ENV=development

# Database (owns ai_db)
DATABASE_URL=postgresql://lms:secret@localhost:5432/ai_db

# JWT (validate tokens — secret shared with auth-service)
JWT_SECRET=change_me_min_32_characters_long!!

# RabbitMQ
RABBITMQ_URL=amqp://lms:lms_secret@localhost:5672
RABBITMQ_EXCHANGE=lms.events

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=120000
