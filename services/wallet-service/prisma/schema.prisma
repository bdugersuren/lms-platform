// Wallet Service — Prisma Schema
// Database: wallet_db
// IMPORTANT: Financial logic MUST be isolated. Never share across services.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WalletStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum TransactionType {
  CREDIT            // Ерөнхий орлого
  WALLET_TOPUP      // Хэтэвч цэнэглэлт (payment-service-ээс)
  DEBIT             // Зарцуулалт
  REVENUE_SHARE     // Орлого хуваалцах (instructor)
  PAYOUT            // Гадагш гаргах
  REFUND            // Буцаалт
  PLATFORM_FEE      // Платформ хураамж
  ADMIN_ADJUSTMENT  // Админ тохируулга
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

model Wallet {
  id        String       @id @default(uuid())
  tenantId  String       @default("demo") @map("tenant_id")
  ownerId   String       @map("owner_id")
  ownerType String       @default("USER") @map("owner_type")
  balance   Decimal      @default(0) @db.Decimal(18, 2)
  currency  String       @default("MNT")
  status    WalletStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  transactions Transaction[]
  payouts      Payout[]
  revenueShares RevenueShare[]

  @@index([tenantId])
  @@index([ownerId])
  @@unique([tenantId, ownerId])
  @@map("wallets")
}

model Transaction {
  id          String            @id @default(uuid())
  walletId    String            @map("wallet_id")
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Decimal           @db.Decimal(18, 2)
  balanceBefore Decimal         @map("balance_before") @db.Decimal(18, 2)
  balanceAfter  Decimal         @map("balance_after") @db.Decimal(18, 2)
  currency    String            @default("MNT")
  description String?
  reference   String?           @unique // idempotency — нэг paymentId-аар давхар credit хийхгүй
  metadata    Json?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([type])
  @@map("transactions")
}

model RevenueShare {
  id           String   @id @default(uuid())
  tenantId     String   @default("demo") @map("tenant_id")
  walletId     String   @map("wallet_id")
  courseId     String   @map("course_id")
  enrollmentId String   @map("enrollment_id")
  grossAmount  Decimal  @map("gross_amount") @db.Decimal(18, 2)
  platformFee  Decimal  @map("platform_fee") @db.Decimal(18, 2)
  netAmount    Decimal  @map("net_amount") @db.Decimal(18, 2)
  feePercent   Decimal  @map("fee_percent") @db.Decimal(5, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@unique([enrollmentId])
  @@index([tenantId])
  @@index([walletId])
  @@index([courseId])
  @@map("revenue_shares")
}

model FeePolicy {
  id            String   @id @default(uuid())
  tenantId      String   @default("demo") @map("tenant_id")
  policyType    String   @default("REVENUE_SHARE") @map("policy_type")
  currency      String   @default("MNT")
  feePercent    Decimal  @default(20) @map("fee_percent") @db.Decimal(5, 2)
  effectiveFrom DateTime @default(now()) @map("effective_from")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId, policyType, isActive])
  @@map("fee_policies")
}

model Payout {
  id            String       @id @default(uuid())
  tenantId      String       @default("demo") @map("tenant_id")
  walletId      String       @map("wallet_id")
  amount        Decimal      @db.Decimal(18, 2)
  currency      String       @default("MNT")
  status        PayoutStatus @default(PENDING)
  bankName      String?      @map("bank_name")
  accountNumber String?      @map("account_number")
  accountName   String?      @map("account_name")
  note          String?
  processedAt   DateTime?    @map("processed_at")
  rejectedReason String?     @map("rejected_reason")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([tenantId])
  @@index([walletId])
  @@index([status])
  @@map("payouts")
}

model CourseProjection {
  courseId       String    @id @map("course_id")
  tenantId       String    @default("demo") @map("tenant_id")
  title          String
  instructorId   String    @map("instructor_id")
  price          Decimal   @default(0) @db.Decimal(10, 2)
  status         String    @default("PUBLISHED")
  contentVersion Int       @default(1) @map("content_version")
  publishedAt    DateTime? @map("published_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([instructorId])
  @@map("course_projections")
}

model EventOutbox {
  id            String    @id @default(uuid())
  eventId       String    @unique @map("event_id")
  eventType     String    @map("event_type")
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  payload       Json
  occurredAt    DateTime  @default(now()) @map("occurred_at")
  publishedAt   DateTime? @map("published_at")
  attempts      Int       @default(0)
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([eventType])
  @@index([aggregateType, aggregateId])
  @@index([publishedAt, occurredAt])
  @@map("event_outbox")
}

model EventFailure {
  id         String    @id @default(uuid())
  eventId    String?   @map("event_id")
  eventType  String    @map("event_type")
  consumer   String
  payload    Json
  errorMsg   String    @map("error_msg")
  stackTrace String?   @map("stack_trace")
  retryCount Int       @default(0) @map("retry_count")
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([eventType])
  @@index([resolvedAt])
  @@map("event_failures")
}
