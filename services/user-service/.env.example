# User Service Environment Variables
PORT=3014
NODE_ENV=development
SERVICE_NAME=user-service

# Database
DATABASE_URL=postgresql://lms:lms_secret@postgres:5432/user_db

# JWT (validation only — user-service does not issue tokens)
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_256_BIT

# RabbitMQ
RABBITMQ_URL=amqp://lms:lms_secret@rabbitmq:5672
RABBITMQ_EXCHANGE=lms.events
