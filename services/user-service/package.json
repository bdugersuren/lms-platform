{
  "name": "@lms/user-service",
  "version": "0.1.0",
  "private": true,
  "description": "LMS User Service — profile, display identity, locale, and onboarding metadata",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "start": "node dist/main.js",
    "start:dev": "nodemon --config ../../nodemon.svc.json",
    "start:dev:once": "ts-node --transpile-only -r tsconfig-paths/register src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:e2e": "jest --config jest-e2e.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lms/shared-auth": "workspace:*",
    "@lms/shared-config": "workspace:*",
    "@lms/shared-types": "workspace:*",
    "@lms/shared-utils": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/microservices": "catalog:",
    "@nestjs/passport": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@nestjs/terminus": "catalog:",
    "swagger-ui-express": "catalog:",
    "@prisma/client": "catalog:",
    "prisma": "catalog:",
    "amqp-connection-manager": "catalog:",
    "amqplib": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "joi": "catalog:",
    "nest-winston": "catalog:",
    "passport": "catalog:",
    "passport-jwt": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "winston": "catalog:"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.3.10",
    "@types/amqplib": "catalog:",
    "@types/express": "catalog:",
    "@types/jest": "^29.5.12",
    "@types/node": "catalog:",
    "@types/passport-jwt": "catalog:",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "typescript": "catalog:",
    "nodemon": "catalog:"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@lms/shared-types": "<rootDir>/../../packages/shared-types/src",
      "@lms/shared-utils": "<rootDir>/../../packages/shared-utils/src",
      "@lms/shared-auth": "<rootDir>/../../packages/shared-auth/src",
      "@lms/shared-config": "<rootDir>/../../packages/shared-config/src"
    }
  }
}
