// Quiz Service — Prisma Schema
// Database: quiz_db
// Each service owns its own schema. Never share across services.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_TEXT
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  EXPIRED
}

model Quiz {
  id          String  @id @default(uuid())
  courseId    String  @map("course_id")
  lessonId    String? @map("lesson_id")
  title       String
  description String?

  passingScore Float @default(70) @map("passing_score")
  timeLimit    Int?  @map("time_limit")
  maxAttempts  Int   @default(3) @map("max_attempts")
  isAdaptive   Boolean @default(false) @map("is_adaptive")
  isPublished  Boolean @default(false) @map("is_published")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  questions Question[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([lessonId])
  @@map("quizzes")
}

model Question {
  id           String       @id @default(uuid())
  quizId       String       @map("quiz_id")
  questionType QuestionType @map("question_type")
  questionText String       @map("question_text")
  explanation  String?
  score        Float        @default(1)
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  quiz    Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuestionOption[]
  answers AttemptAnswer[]

  @@index([quizId])
  @@map("questions")
}

model QuestionOption {
  id         String  @id @default(uuid())
  questionId String  @map("question_id")
  optionText String  @map("option_text")
  isCorrect  Boolean @default(false) @map("is_correct")
  sortOrder  Int     @default(0) @map("sort_order")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

model QuizAttempt {
  id          String        @id @default(uuid())
  quizId      String        @map("quiz_id")
  studentId   String        @map("student_id")
  status      AttemptStatus @default(IN_PROGRESS)
  score       Float         @default(0)
  passed      Boolean       @default(false)
  startedAt   DateTime      @default(now()) @map("started_at")
  submittedAt DateTime?     @map("submitted_at")
  expiresAt   DateTime?     @map("expires_at")

  quiz    Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers AttemptAnswer[]

  @@index([quizId])
  @@index([studentId])
  @@map("quiz_attempts")
}

model AttemptAnswer {
  id               String  @id @default(uuid())
  attemptId        String  @map("attempt_id")
  questionId       String  @map("question_id")
  selectedOptionIds String[] @map("selected_option_ids")
  textAnswer       String? @map("text_answer")
  isCorrect        Boolean @default(false) @map("is_correct")
  score            Float   @default(0)

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@map("attempt_answers")
}
