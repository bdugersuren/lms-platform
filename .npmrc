# =============================================================================
# pnpm configuration — workspace-wide
# =============================================================================

# Use the content-addressable store at a fixed location so BuildKit cache
# mounts always hit the same path across all Docker builds.
store-dir=~/.local/share/pnpm/store

# Hoist nothing by default — every package gets its own node_modules.
# This prevents phantom dependency bugs and matches Kubernetes isolation.
shamefully-hoist=false
hoist=false

# Do not fail on peer dep mismatches (NestJS ecosystem has many of these).
strict-peer-dependencies=false
auto-install-peers=true

# Link workspace packages by their declared exports (requires built dist/).
# Prevents importing raw TS source across packages in production.
link-workspace-packages=true

# Speed: do not verify store integrity on every install (CI should use --frozen-lockfile).
verify-store-integrity=false

# Prefer offline — use cached packages first, only hit registry when needed.
prefer-offline=true
