# =============================================================================
# DMOJ Online Judge — Environment Variables
# Copy: cp .env.dmoj.example .env.dmoj
# Also copy: infra/dmoj/environment/*.env.example → *.env (нууц үгнүүдийг тохируулна)
# =============================================================================

# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=dmoj_root_change_me
MYSQL_PASSWORD=dmoj_pass_change_me

# ── DMOJ Site ──────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(50))"
DMOJ_SECRET_KEY=change-me-generate-a-long-random-secret-key
DMOJ_ALLOWED_HOSTS=localhost,127.0.0.1,dmoj-site
DMOJ_DEBUG=0

# ── Judge ──────────────────────────────────────────────────────────────────
DMOJ_JUDGE_KEY=lms-judge-01
JUDGE_SERVER_SHARED_SECRET=lms-judge-secret

# =============================================================================
# LMS coding-service → DMOJ холболт
# Эдгээрийг main .env файлд нэмэх
# =============================================================================

# DMOJ API base URL (Docker network дотроос: http://dmoj-site:8000)
DMOJ_BASE_URL=http://dmoj-site:8000

# Shared secret between coding-service and DMOJ bridge
DMOJ_INTERNAL_SECRET=change-me-internal-secret

# Polling interval milliseconds (5000 = 5 секунд)
DMOJ_RESULT_SYNC_INTERVAL_MS=5000
