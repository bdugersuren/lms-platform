# =============================================================================
# DMOJ Online Judge — Environment Variables
# Copy this file to .env.dmoj and fill in the values.
# =============================================================================

# DMOJ Django secret key (generate with: python -c "import secrets; print(secrets.token_hex(50))")
DMOJ_SECRET_KEY=change-me-generate-a-long-random-secret-key

# DMOJ database password
DMOJ_DB_ROOT_PASSWORD=dmoj_root_change_me
DMOJ_DB_PASSWORD=dmoj_pass_change_me

# DMOJ allowed hosts (comma-separated)
DMOJ_ALLOWED_HOSTS=localhost,127.0.0.1,dmoj-site

# DMOJ debug mode (0 = production, 1 = debug)
DMOJ_DEBUG=0

# Judge authentication key (must match infra/dmoj/local_settings.py judge list)
DMOJ_JUDGE_KEY=lms-judge-01

# =============================================================================
# LMS coding-service connection to DMOJ
# Add these to your main .env file as well
# =============================================================================

# DMOJ API base URL (from within Docker network: http://dmoj-site:8000)
DMOJ_BASE_URL=http://dmoj-site:8000

# Shared secret between coding-service and DMOJ bridge (Phase 2)
DMOJ_INTERNAL_SECRET=change-me-internal-secret

# Polling interval in milliseconds (default: 5000 = 5 seconds)
DMOJ_RESULT_SYNC_INTERVAL_MS=5000
