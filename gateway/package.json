{
  "name": "@lms/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "LMS API Gateway — JWT validation, rate limiting, request proxying",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "start": "node dist/main.js",
    "start:dev": "nodemon --config ../nodemon.gateway.json",
    "start:dev:once": "ts-node --transpile-only -r tsconfig-paths/register src/main.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lms/shared-auth": "workspace:*",
    "@lms/shared-config": "workspace:*",
    "@lms/shared-types": "workspace:*",
    "@lms/shared-utils": "workspace:*",
    "@nestjs/axios": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/passport": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@nestjs/terminus": "catalog:",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/platform-fastify": "^10.3.10",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "axios": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "fastify": "^4.28.0",
    "joi": "catalog:",
    "minio": "catalog:",
    "nest-winston": "catalog:",
    "passport": "catalog:",
    "passport-jwt": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "uuid": "catalog:",
    "winston": "catalog:"
  },
  "devDependencies": {
    "@types/minio": "^7.0.0",
    "@types/node": "catalog:",
    "@types/passport-jwt": "catalog:",
    "@types/uuid": "catalog:",
    "nodemon": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "typescript": "catalog:"
  }
}
