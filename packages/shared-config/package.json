{
  "name": "@lms/shared-config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared NestJS configuration factories with Joi validation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/config": "catalog:",
    "joi": "catalog:"
  },
  "devDependencies": {
    "@nestjs/common": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
