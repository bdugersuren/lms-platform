{
  "name": "@lms/shared-utils",
  "version": "0.1.0",
  "private": true,
  "description": "Shared utilities: logger, crypto, pagination, response builder",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "bcryptjs": "catalog:",
    "winston": "catalog:",
    "winston-daily-rotate-file": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@lms/shared-types": "workspace:*"
  }
}
