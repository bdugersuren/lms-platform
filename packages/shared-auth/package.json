{
  "name": "@lms/shared-auth",
  "version": "0.1.0",
  "private": true,
  "description": "Shared NestJS auth guards, decorators, and strategies",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/passport": "catalog:",
    "passport": "catalog:",
    "passport-jwt": "catalog:",
    "reflect-metadata": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/passport-jwt": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@lms/shared-types": "workspace:*"
  }
}
